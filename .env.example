# orga-drone local environment example
# Copy to .env and adjust. Never commit real secrets or personal paths.

# Host/port for the local web UI
ORGA_DRONE_HOST=127.0.0.1
ORGA_DRONE_PORT=8765

# Optional: override data directory (default: platform app data folder)
# ORGA_DRONE_DATA_DIR=

# Default UI language: de | en
ORGA_DRONE_LANG=de

# Force system browser instead of the native desktop window (pywebview)
# ORGA_DRONE_BROWSER=1
